# Copia a .env y completa los valores. No subas .env a git.

# Telegram (formulario de contacto)
VITE_TELEGRAM_BOT_TOKEN=tu_token_de_botfather
VITE_TELEGRAM_CHAT_ID=tu_chat_id_numerico

# Firebase (registro / inicio de sesión)
# Crea un proyecto en https://console.firebase.google.com → Authentication → Email/Password
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
